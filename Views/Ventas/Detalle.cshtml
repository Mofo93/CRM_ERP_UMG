@model CRM_ERP_UMG.Models.Venta

@{
    ViewData["Title"] = "Detalle de Venta";
}

<div class="container-fluid px-4 py-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-5">

        <div>

            <h1 class="fw-bold mb-2"
                style="color: #4b3a30; font-size: 38px;">

                Detalle de Venta

            </h1>

            <p class="mb-0"
               style="color: #8b735f; font-size: 15px;">

                Información completa de la venta
                <span class="fw-semibold">@Model.NumeroVenta</span>

            </p>

        </div>

        <span class="px-4 py-3 rounded-4 fw-semibold shadow-sm"
              style="background-color: #d8f3dc; color: #2d6a4f;">

            <i class="bi bi-check-circle-fill me-2"></i>
            @Model.Estado

        </span>

    </div>

    <!-- MAIN CARD -->
    <div class="card border-0 rounded-5 overflow-hidden shadow-lg"
         style="background-color: #fffaf5;">

        <!-- TOP -->
        <div class="px-5 py-4"
             style="background: linear-gradient(135deg, #9c6644, #7f5539);">

            <div class="d-flex align-items-center">

                <div class="rounded-4 d-flex justify-content-center align-items-center me-4"
                     style="width: 75px; height: 75px; background: rgba(255,255,255,0.15);">

                    <i class="bi bi-receipt-cutoff"
                       style="font-size: 32px; color: white;"></i>

                </div>

                <div>

                    <h2 class="fw-bold text-white mb-1">
                        Venta @Model.NumeroVenta
                    </h2>

                    <span style="color: #f5ebe0;">
                        Resumen, cliente, productos y totales
                    </span>

                </div>

            </div>

        </div>

        <!-- BODY -->
        <div class="card-body p-5">

            <!-- INFO BLOCKS -->
            <div class="row g-4 mb-5">

                <div class="col-md-6">

                    <div class="rounded-4 p-4 h-100 shadow-sm"
                         style="background-color: #f8f1eb; border: 1px solid #ead7c8;">

                        <h5 class="fw-bold mb-4"
                            style="color: #5c4435;">

                            <i class="bi bi-info-circle-fill me-2"
                               style="color: #9c6644;"></i>
                            Información de la Venta

                        </h5>

                        <p style="color: #5c4435;">
                            <strong>Fecha:</strong>
                            @Model.FechaVenta.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                        </p>

                        <p class="mb-0"
                           style="color: #5c4435;">
                            <strong>Vendedor:</strong>
                            @(Model.Usuario?.UserName ?? "Sistema")
                        </p>

                    </div>

                </div>

                <div class="col-md-6">

                    <div class="rounded-4 p-4 h-100 shadow-sm"
                         style="background-color: #f8f1eb; border: 1px solid #ead7c8;">

                        <h5 class="fw-bold mb-4"
                            style="color: #5c4435;">

                            <i class="bi bi-person-fill me-2"
                               style="color: #9c6644;"></i>
                            Cliente

                        </h5>

                        <p style="color: #5c4435;">
                            <strong>Nombre:</strong>
                            @(Model.Cliente?.Nombre ?? "Consumidor Final")
                        </p>

                        <p class="mb-0"
                           style="color: #5c4435;">
                            <strong>NIT/ID:</strong>
                            @(Model.Cliente?.Nit ?? "C/F")
                        </p>

                    </div>

                </div>

            </div>

            <!-- TABLE -->
            <div class="table-responsive mb-5">

                <table class="table align-middle mb-0">

                    <thead>

                        <tr style="border-bottom: 1px solid #ead7c8;">

                            <th class="border-0 py-4"
                                style="color: #8b735f; font-size: 13px; letter-spacing: 1px;">
                                PRODUCTO
                            </th>

                            <th class="border-0 py-4 text-center"
                                style="color: #8b735f; font-size: 13px; letter-spacing: 1px;">
                                CANTIDAD
                            </th>

                            <th class="border-0 py-4 text-end"
                                style="color: #8b735f; font-size: 13px; letter-spacing: 1px;">
                                PRECIO UNITARIO
                            </th>

                            <th class="border-0 py-4 text-end"
                                style="color: #8b735f; font-size: 13px; letter-spacing: 1px;">
                                SUBTOTAL
                            </th>

                        </tr>

                    </thead>

                    <tbody>

                        @if (Model.Detalles != null)
                        {
                            foreach (var detalle in Model.Detalles)
                            {
                                <tr style="border-bottom: 1px solid #f1e4d8;">

                                    <td class="py-4">

                                        <div class="fw-bold"
                                             style="color: #4b3a30;">
                                            @detalle.Producto?.Nombre
                                        </div>

                                    </td>

                                    <td class="py-4 text-center">

                                        <span class="px-3 py-2 rounded-pill fw-semibold"
                                              style="background-color: #ede0d4; color: #6b4f3f;">

                                            @detalle.Cantidad

                                        </span>

                                    </td>

                                    <td class="py-4 text-end"
                                        style="color: #5c4435;">

                                        Q @detalle.PrecioUnitario.ToString("N2")

                                    </td>

                                    <td class="py-4 text-end fw-bold"
                                        style="color: #7f5539;">

                                        Q @detalle.Subtotal.ToString("N2")

                                    </td>

                                </tr>
                            }
                        }

                    </tbody>

                </table>

            </div>

            <!-- TOTALS -->
            <div class="row justify-content-end">

                <div class="col-lg-5 col-md-7">

                    <div class="rounded-5 p-4 shadow-sm"
                         style="background-color: #f8f1eb; border: 1px solid #ead7c8;">

                        <div class="d-flex justify-content-between mb-3"
                             style="color: #5c4435;">

                            <span>Subtotal</span>
                            <strong>Q @Model.Subtotal.ToString("N2")</strong>

                        </div>

                        <div class="d-flex justify-content-between mb-3"
                             style="color: #b02a37;">

                            <span>Descuento</span>
                            <strong>Q @Model.Descuento.ToString("N2")</strong>

                        </div>

                        <div class="d-flex justify-content-between mb-4"
                             style="color: #5c4435;">

                            <span>IVA 12%</span>
                            <strong>Q @Model.Impuesto.ToString("N2")</strong>

                        </div>

                        <hr style="border-color: #d8c3b3;" />

                        <div class="d-flex justify-content-between align-items-center mt-4">

                            <span class="fw-bold"
                                  style="color: #4b3a30; font-size: 20px;">
                                Total
                            </span>

                            <span class="fw-bold"
                                  style="color: #7f5539; font-size: 28px;">
                                Q @Model.Total.ToString("N2")
                            </span>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- FOOTER -->
        <div class="card-footer border-0 p-4"
             style="background-color: #fffaf5;">

            <a asp-action="Index"
               class="btn px-4 py-3 rounded-4 fw-semibold shadow-sm border-0"
               style="background-color: #ede0d4; color: #6b4f3f;">

                <i class="bi bi-arrow-left-circle me-2"></i>
                Volver al Listado

            </a>

        </div>

    </div>

</div>