@model CRM_ERP_UMG.Models.Venta

@{
    ViewData["Title"] = "Detalle de Venta";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h2 class="mb-0">Detalle de Venta: @Model.NumeroVenta</h2>
            <span class="badge bg-success fs-6">@Model.Estado</span>
        </div>
        <div class="card-body">
            <div class="row mb-4">
                <div class="col-md-6">
                    <h5><strong>Información de la Venta</strong></h5>
                    <p><strong>Fecha:</strong> @Model.FechaVenta.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                    <p><strong>Vendedor:</strong> @(Model.Usuario?.UserName ?? "Sistema")</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <h5><strong>Cliente</strong></h5>
                    <p><strong>Nombre:</strong> @(Model.Cliente?.Nombre ?? "Consumidor Final")</p>
                    <p><strong>NIT/ID:</strong> @(Model.Cliente?.Nit ?? "C/F")</p>
                </div>
            </div>

            <table class="table table-striped table-bordered">
                <thead class="table-dark">
                    <tr>
                        <th>Producto</th>
                        <th class="text-center">Cantidad</th>
                        <th class="text-end">Precio Unitario</th>
                        <th class="text-end">Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Detalles != null)
                    {
                        foreach (var detalle in Model.Detalles)
                        {
                            <tr>
                                <td>@detalle.Producto?.Nombre</td>
                                <td class="text-center">@detalle.Cantidad</td>
                                <td class="text-end">Q @detalle.PrecioUnitario.ToString("N2")</td>
                                <td class="text-end">Q @detalle.Subtotal.ToString("N2")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>

            <div class="row justify-content-end mt-4">
                <div class="col-md-4 text-end">
                    <p class="fs-5"><strong>Subtotal:</strong> Q @Model.Subtotal.ToString("N2")</p>
                    <p class="fs-5 text-danger"><strong>Descuento:</strong> Q @Model.Descuento.ToString("N2")</p>
                    <p class="fs-5 text-primary"><strong>IVA (12%):</strong> Q @Model.Impuesto.ToString("N2")</p>
                    <hr />
                    <h3 class="text-success"><strong>Total:</strong> Q @Model.Total.ToString("N2")</h3>
                </div>
            </div>
        </div>
        <div class="card-footer text-muted">
            <a asp-action="Index" class="btn btn-secondary">Volver al Listado</a>
        </div>
    </div>
</div>