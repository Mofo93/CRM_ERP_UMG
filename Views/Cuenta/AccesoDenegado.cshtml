<div class="container-fluid px-4 mt-5">

    <div class="row justify-content-center">

        <div class="col-lg-6">

            <div class="card border-0 rounded-5 overflow-hidden shadow-lg"
                 style="background-color: #fffaf5;">

                <!-- HEADER -->
                <div class="text-center p-5"
                     style="background: linear-gradient(135deg, #9c6644, #7f5539);">

                    <div class="rounded-circle d-inline-flex justify-content-center align-items-center shadow"
                         style="
                            width: 95px;
                            height: 95px;
                            background: rgba(255,255,255,0.15);">

                        <i class="bi bi-shield-lock-fill"
                           style="
                                font-size: 42px;
                                color: white;"></i>

                    </div>

                    <h2 class="fw-bold text-white mt-4 mb-2">

                        Acceso Denegado

                    </h2>

                    <p class="mb-0"
                       style="
                            color: #f5ebe0;
                            font-size: 15px;">

                        No cuentas con permisos para acceder a esta sección

                    </p>

                </div>

                <!-- BODY -->
                <div class="card-body text-center p-5">

                    <div class="mb-4">

                        <div class="rounded-4 p-4"
                             style="
                                background-color: #f8f1eb;
                                border: 1px solid #eaded3;">

                            <i class="bi bi-exclamation-triangle-fill mb-3"
                               style="
                                    font-size: 45px;
                                    color: #b08968;"></i>

                            <h5 class="fw-bold mb-2"
                                style="color: #5c4435;">

                                Permisos insuficientes

                            </h5>

                            <p class="mb-0"
                               style="
                                    color: #8b735f;
                                    font-size: 15px;">

                                Solicita acceso con un administrador del sistema
                                para continuar.

                            </p>

                        </div>

                    </div>

                    <!-- BUTTON -->
                    <a class="btn px-5 py-3 rounded-4 fw-semibold shadow border-0"
                       asp-controller="Modulos"
                       asp-action="Index"
                       style="
                            background: linear-gradient(135deg, #b08968, #7f5539);
                            color: white;">

                        <i class="bi bi-arrow-left-circle-fill me-2"></i>
                        Volver al Panel

                    </a>

                </div>

            </div>

        </div>

    </div>

</div>