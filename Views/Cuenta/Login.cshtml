@model LoginVista

<div class="container-fluid p-0">

    <div class="row g-0"
         style="min-height: 100vh;">

        <!-- LEFT PANEL -->
        <div class="col-lg-7 d-none d-lg-flex flex-column justify-content-between p-5"
             style="
                background:
                linear-gradient(
                135deg,
                #b7a391 0%,
                #a28c7a 45%,
                #8b6f5c 100%);
                position: relative;
                overflow: hidden;">

            <!-- ABSTRACT SHAPES -->
            <div style="
                    position: absolute;
                    width: 450px;
                    height: 450px;
                    border-radius: 50%;
                    background: rgba(255,255,255,0.05);
                    top: -120px;
                    left: -120px;
                    filter: blur(8px);">
            </div>

            <div style="
                    position: absolute;
                    width: 320px;
                    height: 320px;
                    border-radius: 50%;
                    background: rgba(255,255,255,0.04);
                    bottom: -80px;
                    right: -80px;">
            </div>

            <!-- LOGO -->
            <div class="position-relative">

                <div class="d-flex align-items-center">

                    <div class="rounded-4 d-flex justify-content-center align-items-center shadow"
                         style="
                            width: 70px;
                            height: 70px;
                            background: rgba(255,255,255,0.10);
                            backdrop-filter: blur(8px);">

                        <i class="bi bi-grid-1x2-fill"
                           style="
                                font-size: 30px;
                                color: white;">
                        </i>

                    </div>

                    <div class="ms-3">

                        <h4 class="fw-bold mb-0 text-white">
                            CRM ERP UMG
                        </h4>

                        <small style="color: rgba(255,255,255,0.70);">
                            Enterprise Management
                        </small>

                    </div>

                </div>

            </div>

            <!-- CENTER TEXT -->
            <div class="position-relative px-4">

               

                <p class="mt-4"
                   style="
                        color: rgba(255,255,255,0.80);
                        font-size: 20px;
                        max-width: 540px;
                        line-height: 1.7;">

                    Plataforma inteligente para la administración,
                    organización y crecimiento de tu empresa.

                </p>

            </div>

            <!-- FOOTER -->
            <div class="position-relative">

                <small style="color: rgba(255,255,255,0.65);">

                    CRM ERP UMG · Sistema empresarial

                </small>

            </div>

        </div>

        <!-- RIGHT PANEL -->
        <div class="col-lg-5 d-flex justify-content-center align-items-center"
             style="
                background-color: #f6f1eb;
                padding: 40px;">

            <div style="
                    width: 100%;
                    max-width: 430px;">

                <!-- MOBILE LOGO -->
                <div class="d-lg-none text-center mb-5">

                    <div class="rounded-4 d-inline-flex justify-content-center align-items-center shadow-sm"
                         style="
                            width: 75px;
                            height: 75px;
                            background: linear-gradient(135deg, #8b6f5c, #6f5646);">

                        <i class="bi bi-grid-1x2-fill text-white"
                           style="font-size: 32px;">
                        </i>

                    </div>

                </div>

                <!-- CARD -->
                <div class="border-0 rounded-5 shadow-lg p-5"
                     style="
                        background-color: rgba(255,255,255,0.72);
                        backdrop-filter: blur(12px);">

                    <div class="mb-5">

                        <h2 class="fw-semibold mb-2"
                            style="
                                color: #4b3b32;
                                font-size: 38px;">

                            Iniciar sesión

                        </h2>

                        <p style="
                                color: #8a796d;
                                font-size: 16px;">

                            Ingresa tus credenciales para continuar

                        </p>

                    </div>

                    <form asp-action="Login" method="post">

                        <input type="hidden" asp-for="ReturnUrl" />

                        <div asp-validation-summary="ModelOnly"
                             class="alert alert-danger rounded-4 border-0 mb-4">
                        </div>

                        <!-- EMAIL -->
                        <div class="mb-4">

                            <label asp-for="Email"
                                   class="form-label fw-semibold mb-3"
                                   style="color: #5a4a40;">

                                Correo electrónico

                            </label>

                            <div class="input-group rounded-4 overflow-hidden shadow-sm">

                                <span class="input-group-text border-0 px-4"
                                      style="
                                        background-color: #efe7df;
                                        color: #7a6658;">

                                    <i class="bi bi-envelope-fill"></i>

                                </span>

                                <input asp-for="Email"
                                       class="form-control border-0 py-3"
                                       placeholder="correo@empresa.com"
                                       style="
                                            background-color: #fcfaf8;
                                            color: #4b3b32;">

                            </div>

                        </div>

                        <!-- PASSWORD -->
                        <div class="mb-4">

                            <label asp-for="Password"
                                   class="form-label fw-semibold mb-3"
                                   style="color: #5a4a40;">

                                Contraseña

                            </label>

                            <div class="input-group rounded-4 overflow-hidden shadow-sm">

                                <span class="input-group-text border-0 px-4"
                                      style="
                                        background-color: #efe7df;
                                        color: #7a6658;">

                                    <i class="bi bi-lock-fill"></i>

                                </span>

                                <input asp-for="Password"
                                       type="password"
                                       class="form-control border-0 py-3"
                                       placeholder="••••••••"
                                       style="
                                            background-color: #fcfaf8;
                                            color: #4b3b32;">

                            </div>

                        </div>
<div class="mt-4">

    <!-- CHECK -->
    <div class="form-check mb-3">

        <input class="form-check-input"
               type="checkbox"
               id="recordarme">

        <label class="form-check-label ms-1"
               for="recordarme"
               style="color: #7a6658;">

            Recordarme

        </label>

    </div>

    <!-- LINK -->
    <a href="#"
       style="
            color: #7a6658;
            text-decoration: none;
            font-weight: 500;">

        ¿Olvidaste tu contraseña?

    </a>

</div>

                        <!-- BUTTON -->
                        <button class="btn w-100 py-3 rounded-4 border-0 fw-semibold shadow-sm"
                                type="submit"
                                style="
                                    background:
                                    linear-gradient(
                                    135deg,
                                    #8b6f5c,
                                    #6f5646);
                                    color: white;
                                    font-size: 16px;">

                            <i class="bi bi-box-arrow-in-right me-2"></i>
                            Ingresar al sistema

                        </button>

                    </form>

                    <!-- DEMO -->
                    <div class="mt-5 text-center">

                        <small style="color: #9c8b80;">

                            Usuario demo

                        </small>

                        <div class="fw-semibold mt-2"
                             style="color: #5a4a40;">

                            admin@umg.com

                        </div>

                        <div class="fw-bold"
                             style="color: #8b6f5c;">

                            Admin123*

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>