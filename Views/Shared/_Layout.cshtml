<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="utf-8" />
<title>CRM ERP UMG</title>
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
rel="stylesheet">
</head>
<body class="bg-light">
<nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
<div class="container-fluid px-4">
<a class="navbar-brand fw-bold" asp-controller="Modulos"
asp-action="Index">CRM ERP UMG</a>
<div class="navbar-nav me-auto">
@if (User.Identity?.IsAuthenticated == true)
{
<a class="nav-link" asp-controller="Modulos"
asp-action="Index">Módulos</a>
<a class="nav-link" asp-controller="Operaciones"
asp-action="Index">Operaciones</a>
<a class="nav-link" asp-controller="Ventas"
asp-action="Index">Ventas</a>
<a class="nav-link" asp-controller="Clientes"
asp-action="Index">Clientes</a>
@if (User.IsInRole("Admin") || User.IsInRole("Editor"))
{
<a class="nav-link" asp-controller="Productos"
asp-action="Index">Productos</a>
}
@if (User.IsInRole("Admin"))
{
<a class="nav-link" asp-controller="Usuarios"
asp-action="Index">Usuarios</a>
}
}
</div>
<div class="navbar-nav">
@if (User.Identity?.IsAuthenticated == true)
{
<span class="navbar-text text-white me-3">
@User.Identity.Name
</span>
<form asp-controller="Cuenta" asp-action="Logout" method="post">
<button class="btn btn-outline-light btn-sm"
type="submit">Salir</button>
</form>
}
else
{
<a class="btn btn-outline-light btn-sm" asp-controller="Cuenta"
asp-action="Login">Ingresar</a>
}
</div>
</div>
</nav>
<main class="container-fluid px-4">
@RenderBody()
</main>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>