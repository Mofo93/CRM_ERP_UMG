<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>CRM ERP UMG</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
          rel="stylesheet">

    <style>

        body {
            margin: 0;
            padding: 0;
            font-family: 'Poppins', sans-serif;

            background:
                radial-gradient(circle at top left, rgba(255,255,255,0.5), transparent 20%),
                linear-gradient(135deg, #f7f3ef, #ebe5dd);

            min-height: 100vh;
            color: #2f2f2f;
        }

        /* NAVBAR */
        .navbar {

            background: rgba(34,34,34,0.95);

            backdrop-filter: blur(10px);

            border-bottom: 1px solid rgba(255,255,255,0.05);

            padding-top: 14px;
            padding-bottom: 14px;

            box-shadow: 0 8px 20px rgba(0,0,0,0.08);
        }

        .navbar-brand {

            color: white !important;
            font-weight: 700;
            letter-spacing: 1px;
            font-size: 1.1rem;
        }

        .nav-link {

            color: rgba(255,255,255,0.75) !important;

            padding: 10px 15px !important;

            border-radius: 14px;

            transition: 0.3s;

            font-weight: 500;
        }

        .nav-link:hover {

            background: rgba(255,255,255,0.08);

            color: white !important;
        }

        /* MAIN CONTENT */
        main {

            padding-top: 10px;
        }

        /* CARDS */
        .card {

            border: none;

            border-radius: 26px;

            background: rgba(255,255,255,0.75);

            backdrop-filter: blur(12px);

            box-shadow:
                0 10px 30px rgba(0,0,0,0.08);

            overflow: hidden;
        }

        /* BUTTONS */
        .btn-primary {

            background: linear-gradient(135deg, #2f2f2f, #575757);

            border: none;

            border-radius: 16px;

            padding: 12px 22px;

            font-weight: 600;
        }

        .btn-primary:hover {

            opacity: 0.92;
        }

        .btn-light {

            border-radius: 16px;

            border: none;

            font-weight: 600;
        }

        /* TABLES */
        .table {

            color: #2f2f2f;
        }

        .table thead {

            background: linear-gradient(135deg, #2f2f2f, #4c4c4c);

            color: white;
        }

        .table thead th {

            border: none;

            padding: 18px;

            font-size: 14px;

            letter-spacing: 1px;
        }

        .table tbody tr {

            transition: 0.3s;
        }

        .table tbody tr:hover {

            background-color: rgba(0,0,0,0.03);
        }

        .table td {

            border: none;

            padding: 18px;

            vertical-align: middle;
        }

        /* FORMS */
        .form-control {

            border: 1px solid #e3ddd5;

            border-radius: 16px;

            padding: 14px;

            background-color: #fffdfb;
        }

        .form-control:focus {

            border-color: #777;

            box-shadow: 0 0 0 0.15rem rgba(0,0,0,0.08);
        }

        /* HEADINGS */
        h1, h2, h3, h4 {

            color: #2f2f2f;

            font-weight: 700;
        }

        /* CUSTOM TAGS */
        .soft-badge {

            background: #efebe6;

            color: #4c4c4c;

            padding: 8px 14px;

            border-radius: 999px;

            font-size: 13px;

            font-weight: 600;
        }

        /* SCROLLBAR */
        ::-webkit-scrollbar {

            width: 10px;
        }

        ::-webkit-scrollbar-thumb {

            background: #8b8b8b;

            border-radius: 20px;
        }

    </style>

</head>

<body>

    @if (!(ViewContext.RouteData.Values["Controller"]?.ToString() == "Cuenta"
       && ViewContext.RouteData.Values["Action"]?.ToString() == "Login"))
    {
        <nav class="navbar navbar-expand-lg navbar-dark mb-4">

            <div class="container-fluid px-4">

                <!-- LOGO -->
                <a class="navbar-brand"
                   asp-controller="Modulos"
                   asp-action="Index">

                    <i class="bi bi-grid-1x2-fill me-2"></i>
                    CRM ERP UMG

                </a>

                <!-- MENU -->
                <div class="navbar-nav me-auto">

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a class="nav-link"
                           asp-controller="Modulos"
                           asp-action="Index">

                            Módulos

                        </a>

                        <a class="nav-link"
                           asp-controller="Operaciones"
                           asp-action="Index">

                            Operaciones

                        </a>

                        <a class="nav-link"
                           asp-controller="Ventas"
                           asp-action="Index">

                            Ventas

                        </a>

                        <a class="nav-link"
                           asp-controller="Clientes"
                           asp-action="Index">

                            Clientes

                        </a>

                        @if (User.IsInRole("Admin") || User.IsInRole("Editor"))
                        {
                            <a class="nav-link"
                               asp-controller="Productos"
                               asp-action="Index">

                                Productos

                            </a>
                        }

                        @if (User.IsInRole("Admin"))
                        {
                            <a class="nav-link"
                               asp-controller="Usuarios"
                               asp-action="Index">

                                Usuarios

                            </a>
                        }
                    }

                </div>

                <!-- USER -->
                <div class="navbar-nav">

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="d-flex align-items-center gap-3">

                            <div class="text-end">

                                <div class="small text-light opacity-75">
                                    Usuario conectado
                                </div>

                                <div class="fw-semibold text-white">
                                    @User.Identity.Name
                                </div>

                            </div>

                            <form asp-controller="Cuenta"
                                  asp-action="Logout"
                                  method="post">

                                <button class="btn btn-light rounded-pill px-4 shadow-sm"
                                        type="submit">

                                    <i class="bi bi-box-arrow-right me-1"></i>
                                    Salir

                                </button>

                            </form>

                        </div>
                    }
                    else
                    {
                        <a class="btn btn-light rounded-pill px-4 shadow-sm"
                           asp-controller="Cuenta"
                           asp-action="Login">

                            Ingresar

                        </a>
                    }

                </div>

            </div>

        </nav>
    }

    <!-- CONTENT -->
    <main class="container-fluid px-4 pb-4">

        @RenderBody()

    </main>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>