@model List<Cliente>

<div class="container mt-4">

    <div class="card border-0 shadow-lg rounded-4">

        <div class="card-header bg-gradient text-white d-flex justify-content-between align-items-center rounded-top-4"
             style="background: linear-gradient(135deg, #4e73df, #224abe);">

            <h2 class="fw-bold m-0">
                <i class="bi bi-people-fill me-2"></i>
                Gestión de Clientes
            </h2>

            <a class="btn btn-light fw-semibold px-4 rounded-pill shadow-sm"
               asp-action="Crear">
                <i class="bi bi-plus-circle me-1"></i>
                Nuevo Cliente
            </a>

        </div>

        <div class="card-body">

            <div class="table-responsive">

                <table class="table align-middle table-hover">

                    <thead style="background-color:#f1f4ff;">
                        <tr>
                            <th>NIT</th>
                            <th>Nombre</th>
                            <th>Teléfono</th>
                            <th>Dirección</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var cliente in Model)
                        {
                            <tr>

                                <td class="fw-semibold text-primary">
                                    @cliente.Nit
                                </td>

                                <td>
                                    @cliente.Nombre
                                </td>

                                <td>
                                    @cliente.Telefono
                                </td>

                                <td>
                                    @cliente.Direccion
                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>