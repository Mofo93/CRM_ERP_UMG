@model List<Cliente>

<div class="container-fluid px-4 py-4">

    <!-- TOP -->
    <div class="d-flex justify-content-between align-items-center mb-5 flex-wrap gap-3">

        <div>

            <h1 class="fw-bold mb-2"
                style="
                    color: #4b3a30;
                    font-size: 38px;">

                Clientes

            </h1>

            <p class="mb-0"
               style="
                    color: #8b735f;
                    font-size: 15px;">

                Gestión y administración de clientes registrados

            </p>

        </div>

        <a asp-action="Crear"
           class="btn border-0 px-4 py-3 rounded-4 fw-semibold shadow"
           style="
                background: linear-gradient(135deg, #b08968, #7f5539);
                color: white;
                min-width: 220px;">

            <i class="bi bi-plus-circle-fill me-2"></i>
            Nuevo Cliente

        </a>

    </div>

    <!-- MAIN PANEL -->
    <div class="card border-0 rounded-5 overflow-hidden shadow-lg"
         style="
            background-color: #fffaf5;">

        <!-- HEADER -->
        <div class="px-5 py-4 d-flex justify-content-between align-items-center flex-wrap gap-3"
             style="
                background: linear-gradient(135deg, #9c6644, #7f5539);">

            <div class="d-flex align-items-center">

                <!-- ICON -->
                <div class="rounded-4 d-flex justify-content-center align-items-center me-4 shadow"
                     style="
                        width: 72px;
                        height: 72px;
                        background: rgba(255,255,255,0.14);">

                    <i class="bi bi-people-fill"
                       style="
                            font-size: 30px;
                            color: white;"></i>

                </div>

                <!-- TEXT -->
                <div>

                    <h3 class="fw-bold text-white mb-1">
                        Gestión de Clientes
                    </h3>

                    <span style="color: #f5ebe0;">

                        Panel general del módulo de clientes

                    </span>

                </div>

            </div>

            <!-- COUNT -->
            <div class="text-end">

                <div class="fw-bold"
                     style="
                        color: white;
                        font-size: 38px;">

                    @Model.Count

                </div>

                <small style="color: #ede0d4;">

                    Registros activos

                </small>

            </div>

        </div>

        <!-- BODY -->
        <div class="p-4">

            <div class="table-responsive">

                <table class="table align-middle mb-0">

                    <thead>

                        <tr style="border-bottom: 1px solid #eaded3;">

                            <th class="border-0 py-4"
                                style="
                                    color: #7f5539;
                                    font-size: 13px;
                                    letter-spacing: 1px;">

                                NIT

                            </th>

                            <th class="border-0 py-4"
                                style="
                                    color: #7f5539;
                                    font-size: 13px;
                                    letter-spacing: 1px;">

                                CLIENTE

                            </th>

                            <th class="border-0 py-4"
                                style="
                                    color: #7f5539;
                                    font-size: 13px;
                                    letter-spacing: 1px;">

                                TELÉFONO

                            </th>

                            <th class="border-0 py-4"
                                style="
                                    color: #7f5539;
                                    font-size: 13px;
                                    letter-spacing: 1px;">

                                DIRECCIÓN

                            </th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var cliente in Model)
                        {
                            <tr style="
                                    border-bottom: 1px solid #f1e5dc;
                                    transition: 0.3s;">

                                <!-- NIT -->
                                <td class="py-4">

                                    <span class="px-3 py-2 rounded-pill fw-semibold"
                                          style="
                                            background-color: #ede0d4;
                                            color: #7f5539;
                                            font-size: 14px;">

                                        @cliente.Nit

                                    </span>

                                </td>

                                <!-- CLIENTE -->
                                <td class="py-4">

                                    <div class="d-flex align-items-center">

                                        <!-- Avatar -->
                                        <div class="rounded-circle d-flex justify-content-center align-items-center me-3 shadow-sm"
                                             style="
                                                width: 52px;
                                                height: 52px;
                                                background: linear-gradient(135deg, #b08968, #7f5539);
                                                color: white;
                                                font-weight: bold;
                                                font-size: 18px;">

                                            @(cliente.Nombre.Substring(0,1).ToUpper())

                                        </div>

                                        <!-- Name -->
                                        <div>

                                            <div class="fw-bold"
                                                 style="
                                                    color: #4b3a30;
                                                    font-size: 16px;">

                                                @cliente.Nombre

                                            </div>

                                            <small style="color: #8b735f;">

                                                Cliente registrado

                                            </small>

                                        </div>

                                    </div>

                                </td>

                                <!-- TELEFONO -->
                                <td class="py-4">

                                    <span style="
                                            color: #5c4435;
                                            font-size: 15px;">

                                        <i class="bi bi-telephone-fill me-2"
                                           style="color: #9c6644;"></i>

                                        @cliente.Telefono

                                    </span>

                                </td>

                                <!-- DIRECCION -->
                                <td class="py-4">

                                    <span style="
                                            color: #5c4435;
                                            font-size: 15px;">

                                        <i class="bi bi-geo-alt-fill me-2"
                                           style="color: #9c6644;"></i>

                                        @cliente.Direccion

                                    </span>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>