@{
var modulo = (ModuloDinamico)ViewBag.Modulo;
}
<h2>Crear operación para @modulo.NombreModulo</h2>
<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
<form asp-action="Crear" method="post" class="card shadow-sm p-4">
<input type="hidden" name="moduloId" value="@modulo.Id" />
<div class="mb-3">
<label class="form-label">Nombre de la operación</label>
<input name="nombreOperacion"
class="form-control"
placeholder="Ejemplo: Reporte de ventas con IVA"
required />
</div>
<div class="mb-4">
<h5>Columnas visibles</h5>
@if (!modulo.EsquemaCampos.Any())
{
<div class="alert alert-warning">
Este módulo no tiene campos. Primero agrega campos al módulo.
</div>
}
else
{
@foreach (var campo in modulo.EsquemaCampos)
{
<div class="form-check">
<input class="form-check-input"
type="checkbox"
name="columnasVisibles"
value="@campo.Key"
id="col_@campo.Key"
checked />
<label class="form-check-label" for="col_@campo.Key">
@campo.Value.Etiqueta <code>@campo.Key</code>
</label>
</div>
}
}
</div>
<div class="mb-4">
<h5>Fórmulas</h5>
<p class="text-muted">
Usa los nombres internos de los campos.
Ejemplo: <code>precio_unitario * cantidad</code>
</p>
<div id="contenedorFormulas">
<div class="row mb-2">
<div class="col-md-4">
<input name="nombresFormula" class="form-control"
placeholder="subtotal" />
</div>
<div class="col-md-8">
<input name="expresionesFormula" class="form-control"
placeholder="precio_unitario * cantidad" />
</div>
</div>
<div class="row mb-2">
<div class="col-md-4">
<input name="nombresFormula" class="form-control" placeholder="iva"
/>
</div>
<div class="col-md-8">
<input name="expresionesFormula" class="form-control"
placeholder="subtotal * 0.12" />
</div>
</div>
<div class="row mb-2">
<div class="col-md-4">
<input name="nombresFormula" class="form-control"
placeholder="total" />
</div>
<div class="col-md-8">
<input name="expresionesFormula" class="form-control"
placeholder="subtotal + iva" />
</div>
</div>
</div>
<button type="button"
class="btn btn-outline-secondary btn-sm"
onclick="agregarFormula()">
Agregar otra fórmula
</button>
</div>
<button class="btn btn-primary" type="submit">
Guardar operación
</button>
<a class="btn btn-secondary"
asp-controller="Modulos"
asp-action="Detalle"
asp-route-id="@modulo.Id">
Cancelar
</a>
</form>
@section Scripts {
<script>
function agregarFormula() {
const contenedor = document.getElementById("contenedorFormulas");
const fila = document.createElement("div");
fila.className = "row mb-2";
fila.innerHTML = `
<div class="col-md-4">
<input name="nombresFormula" class="form-control"
placeholder="nombre_resultado" />
</div>
<div class="col-md-8">
<input name="expresionesFormula" class="form-control"
placeholder="campo1 + campo2" />
</div>
`;
contenedor.appendChild(fila);
}
</script>
}
