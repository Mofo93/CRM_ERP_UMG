@model List<Dictionary<string, object>>

@{
    var operacion = (OperacionDinamica)ViewBag.Operacion;
}

<div class="container-fluid px-4 py-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-5">

        <div>

            <h1 class="fw-bold mb-2"
                style="
                    color: #4b3a30;
                    font-size: 38px;">

                @operacion.NombreOperacion

            </h1>

            <p class="mb-0"
               style="
                    color: #8b735f;
                    font-size: 15px;">

                Resultados dinámicos procesados del módulo
                <span class="fw-semibold">@operacion.Modulo?.NombreModulo</span>

            </p>

        </div>

        <div class="rounded-4 px-4 py-3 shadow-sm"
             style="
                background-color: #ede0d4;
                color: #6b4f3f;">

            <div class="fw-bold"
                 style="font-size: 26px;">

                @Model.Count

            </div>

            <small>
                Registros procesados
            </small>

        </div>

    </div>

    <!-- MAIN CARD -->
    <div class="card border-0 rounded-5 overflow-hidden shadow-lg"
         style="background-color: #fffaf5;">

        <!-- TOP -->
        <div class="px-5 py-4 d-flex justify-content-between align-items-center flex-wrap gap-3"
             style="
                background: linear-gradient(135deg, #9c6644, #7f5539);">

            <div class="d-flex align-items-center">

                <!-- ICON -->
                <div class="rounded-4 d-flex justify-content-center align-items-center me-4"
                     style="
                        width: 75px;
                        height: 75px;
                        background: rgba(255,255,255,0.15);">

                    <i class="bi bi-bar-chart-line-fill"
                       style="
                            font-size: 30px;
                            color: white;"></i>

                </div>

                <!-- TEXT -->
                <div>

                    <h2 class="fw-bold text-white mb-1">

                        Resultado de Operación

                    </h2>

                    <span style="color: #f5ebe0;">

                        Visualización de cálculos y fórmulas dinámicas

                    </span>

                </div>

            </div>

        </div>

        <!-- BODY -->
        <div class="card-body p-4">

            @if (!Model.Any())
            {
                <div class="rounded-4 p-5 text-center shadow-sm"
                     style="
                        background-color: #f8f1eb;
                        border: 1px solid #ead7c8;">

                    <i class="bi bi-database-x"
                       style="
                            font-size: 60px;
                            color: #b08968;"></i>

                    <h4 class="fw-bold mt-4 mb-2"
                        style="color: #5c4435;">

                        No hay registros disponibles

                    </h4>

                    <p class="mb-0"
                       style="color: #8b735f;">

                        Este módulo todavía no contiene información para procesar.

                    </p>

                </div>
            }
            else
            {
                <div class="table-responsive">

                    <table class="table align-middle mb-0">

                        <thead>

                            <tr style="border-bottom: 1px solid #ead7c8;">

                                @foreach (var columna in operacion.ColumnasVisibles)
                                {
                                    <th class="border-0 py-4"
                                        style="
                                            color: #8b735f;
                                            font-size: 13px;
                                            letter-spacing: 1px;">

                                        @columna.ToUpper()

                                    </th>
                                }

                                @foreach (var formula in operacion.Formulas)
                                {
                                    <th class="border-0 py-4"
                                        style="
                                            color: #9c6644;
                                            font-size: 13px;
                                            letter-spacing: 1px;">

                                        @formula.NombreResultado.ToUpper()

                                    </th>
                                }

                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var fila in Model)
                            {
                                <tr style="
                                        border-bottom: 1px solid #f1e4d8;
                                        transition: 0.3s;">

                                    <!-- COLUMNAS -->
                                    @foreach (var columna in operacion.ColumnasVisibles)
                                    {
                                        <td class="py-4"
                                            style="
                                                color: #4b3a30;
                                                font-size: 15px;">

                                            @fila[columna]

                                        </td>
                                    }

                                    <!-- FORMULAS -->
                                    @foreach (var formula in operacion.Formulas)
                                    {
                                        <td class="py-4">

                                            <span class="px-3 py-2 rounded-pill fw-bold"
                                                  style="
                                                    background-color: #efe3d8;
                                                    color: #7f5539;
                                                    font-size: 14px;">

                                                @fila[formula.NombreResultado]

                                            </span>

                                        </td>
                                    }

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>
            }

        </div>

    </div>

    <!-- FORMULAS -->
    <div class="card border-0 rounded-5 shadow-lg mt-5"
         style="background-color: #fffaf5;">

        <!-- HEADER -->
        <div class="px-5 py-4"
             style="
                background: linear-gradient(135deg, #b08968, #7f5539);">

            <div class="d-flex align-items-center">

                <div class="rounded-4 d-flex justify-content-center align-items-center me-4"
                     style="
                        width: 65px;
                        height: 65px;
                        background: rgba(255,255,255,0.15);">

                    <i class="bi bi-calculator-fill"
                       style="
                            font-size: 28px;
                            color: white;"></i>

                </div>

                <div>

                    <h3 class="fw-bold text-white mb-1">

                        Fórmulas utilizadas

                    </h3>

                    <span style="color: #f5ebe0;">

                        Expresiones dinámicas configuradas en esta operación

                    </span>

                </div>

            </div>

        </div>

        <!-- BODY -->
        <div class="card-body p-5">

            <div class="row g-4">

                @foreach (var formula in operacion.Formulas)
                {
                    <div class="col-lg-6">

                        <div class="rounded-4 p-4 shadow-sm h-100"
                             style="
                                background-color: #f8f1eb;
                                border: 1px solid #ead7c8;">

                            <div class="fw-bold mb-3"
                                 style="
                                    color: #6b4f3f;
                                    font-size: 16px;">

                                @formula.NombreResultado

                            </div>

                            <code style="
                                    color: #9c6644;
                                    font-size: 14px;">

                                @formula.NombreResultado =
                                @formula.Expresion

                            </code>

                        </div>

                    </div>
                }

            </div>

        </div>

    </div>

    <!-- BUTTON -->
    <div class="mt-4">

        <a class="btn px-4 py-3 rounded-4 fw-semibold shadow-sm border-0"
           asp-action="Index"
           asp-route-moduloId="@operacion.ModuloDinamicoId"
           style="
                background-color: #ede0d4;
                color: #6b4f3f;">

            <i class="bi bi-arrow-left-circle me-2"></i>
            Volver a operaciones

        </a>

    </div>

</div>