@model RegistroDinamico
@functions {
string TipoInput(string tipo)
{
return tipo switch
{
"numero" => "number",
"fecha" => "date",
_ => "text"
};
}
}
<h2>Editar registro: @Model.Modulo!.NombreModulo</h2>
<form asp-action="Editar" method="post" class="card shadow-sm p-4">
<input type="hidden" name="id" value="@Model.Id" />
@foreach (var campo in Model.Modulo.EsquemaCampos)
{
var valor = Model.Datos.ContainsKey(campo.Key) ? Model.Datos[campo.Key] :
"";
<div class="mb-3">
<label class="form-label">@campo.Value.Etiqueta</label>
@if (campo.Value.TipoCampo == "booleano")
{
<select name="@campo.Key" class="form-select">
<option value="No" selected="@(valor == "No")">No</option>
<option value="Sí" selected="@(valor == "Sí")">Sí</option>
</select>
}
else
{
<input name="@campo.Key"
type="@TipoInput(campo.Value.TipoCampo)"
step="any"
value="@valor"
class="form-control"
required="@campo.Value.Requerido" />
}
</div>
}
<button class="btn btn-primary" type="submit">Guardar cambios</button>
<a class="btn btn-secondary" asp-action="Index"
asp-route-moduloId="@Model.ModuloDinamicoId">Cancelar</a>
</form>