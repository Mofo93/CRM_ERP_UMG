@{
    var modulo = (ModuloDinamico)ViewBag.Modulo;
}

@functions {

    string TipoInput(string tipo)
    {
        return tipo switch
        {
            "numero" => "number",
            "fecha" => "date",
            _ => "text"
        };
    }

    string IconoCampo(string tipo)
    {
        return tipo switch
        {
            "numero" => "bi-123",
            "fecha" => "bi-calendar-event-fill",
            "booleano" => "bi-check2-square",
            _ => "bi-pencil-fill"
        };
    }

}

<div class="container-fluid px-4 py-4">

    <!-- HEADER -->
    <div class="mb-5">

        <h1 class="fw-bold mb-2"
            style="color: #4b3a30;">

            Nuevo Registro

        </h1>

        <p style="
                color: #8b735f;
                font-size: 15px;">

            Registro dinámico de información para el módulo:
            <span class="fw-semibold">@modulo.NombreModulo</span>

        </p>

    </div>

    <div class="row justify-content-center">

        <div class="col-xl-8 col-lg-10">

            <!-- CARD -->
            <div class="card border-0 rounded-5 overflow-hidden shadow-lg"
                 style="background-color: #fffaf5;">

                <!-- TOP -->
                <div class="px-5 py-4"
                     style="background: linear-gradient(135deg, #9c6644, #7f5539);">

                    <div class="d-flex align-items-center">

                        <!-- ICON -->
                        <div class="rounded-4 d-flex justify-content-center align-items-center me-4"
                             style="
                                width: 75px;
                                height: 75px;
                                background: rgba(255,255,255,0.15);">

                            <i class="bi bi-database-fill-add"
                               style="
                                    font-size: 32px;
                                    color: white;"></i>

                        </div>

                        <!-- TEXT -->
                        <div>

                            <h2 class="fw-bold text-white mb-1">

                                Crear Registro

                            </h2>

                            <span style="color: #f5ebe0;">

                                Captura y almacenamiento dinámico de información

                            </span>

                        </div>

                    </div>

                </div>

                <!-- BODY -->
                <div class="card-body p-5">

                    <form asp-action="Crear" method="post">

                        <input type="hidden"
                               name="moduloId"
                               value="@modulo.Id" />

                        <div class="row g-4">

                            @foreach (var campo in modulo.EsquemaCampos)
                            {
                                <div class="col-md-6">

                                    <!-- LABEL -->
                                    <label class="form-label fw-semibold mb-2"
                                           style="color: #5c4435;">

                                        @campo.Value.Etiqueta

                                        @if (campo.Value.Requerido)
                                        {
                                            <span style="color: #b02a37;">*</span>
                                        }

                                    </label>

                                    @if (campo.Value.TipoCampo == "booleano")
                                    {
                                        <!-- BOOLEAN -->
                                        <div class="input-group shadow-sm rounded-4 overflow-hidden">

                                            <span class="input-group-text border-0 px-4"
                                                  style="background-color: #efe3d8;">

                                                <i class="bi @IconoCampo(campo.Value.TipoCampo)"
                                                   style="color: #9c6644;"></i>

                                            </span>

                                            <select name="@campo.Key"
                                                    class="form-select border-0 py-3"
                                                    style="
                                                        background-color: #fffdfb;
                                                        color: #4b3a30;">

                                                <option value="No">No</option>
                                                <option value="Sí">Sí</option>

                                            </select>

                                        </div>
                                    }
                                    else
                                    {
                                        <!-- INPUT -->
                                        <div class="input-group shadow-sm rounded-4 overflow-hidden">

                                            <span class="input-group-text border-0 px-4"
                                                  style="background-color: #efe3d8;">

                                                <i class="bi @IconoCampo(campo.Value.TipoCampo)"
                                                   style="color: #9c6644;"></i>

                                            </span>

                                            <input name="@campo.Key"
                                                   type="@TipoInput(campo.Value.TipoCampo)"
                                                   step="any"
                                                   class="form-control border-0 py-3"
                                                   style="
                                                        background-color: #fffdfb;
                                                        color: #4b3a30;"
                                                   required="@campo.Value.Requerido" />

                                        </div>
                                    }

                                </div>
                            }

                        </div>

                        <!-- ACTIONS -->
                        <div class="d-flex justify-content-between align-items-center mt-5 flex-wrap gap-3">

                            <a asp-action="Index"
                               asp-route-moduloId="@modulo.Id"
                               class="btn px-4 py-3 rounded-4 fw-semibold shadow-sm border-0"
                               style="
                                    background-color: #ede0d4;
                                    color: #6b4f3f;">

                                <i class="bi bi-arrow-left-circle me-2"></i>
                                Cancelar

                            </a>

                            <button type="submit"
                                    class="btn px-5 py-3 rounded-4 fw-bold shadow-lg border-0"
                                    style="
                                        background: linear-gradient(135deg, #b08968, #7f5539);
                                        color: white;">

                                <i class="bi bi-check-circle-fill me-2"></i>
                                Guardar Registro

                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>