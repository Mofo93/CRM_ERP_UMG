@model List<UsuarioListadoVista>

<div class="container-fluid px-4 py-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-5 flex-wrap gap-3">

        <div>

            <h1 class="fw-bold mb-2"
                style="
                    color: #4b3a30;
                    font-size: 38px;">

                Usuarios y Roles

            </h1>

            <p class="mb-0"
               style="
                    color: #8b735f;
                    font-size: 15px;">

                Administración de accesos, permisos y perfiles del sistema

            </p>

        </div>

        <a asp-action="Crear"
           class="btn px-4 py-3 rounded-4 fw-semibold shadow-sm border-0"
           style="
                background: linear-gradient(135deg, #b08968, #7f5539);
                color: white;
                min-width: 220px;">

            <i class="bi bi-person-plus-fill me-2"></i>
            Crear Usuario

        </a>

    </div>

    <!-- MAIN CARD -->
    <div class="card border-0 rounded-5 overflow-hidden shadow-lg"
         style="
            background-color: #fffaf5;">

        <!-- HEADER CARD -->
        <div class="px-5 py-4 d-flex justify-content-between align-items-center flex-wrap gap-3"
             style="
                background: linear-gradient(135deg, #9c6644, #7f5539);">

            <div class="d-flex align-items-center">

                <!-- ICON -->
                <div class="rounded-4 d-flex justify-content-center align-items-center me-4"
                     style="
                        width: 70px;
                        height: 70px;
                        background: rgba(255,255,255,0.15);">

                    <i class="bi bi-people-fill"
                       style="
                            font-size: 30px;
                            color: white;"></i>

                </div>

                <!-- TEXT -->
                <div>

                    <h3 class="fw-bold text-white mb-1">

                        Gestión de Usuarios

                    </h3>

                    <span style="color: #f5ebe0;">

                        Control de permisos y roles del sistema

                    </span>

                </div>

            </div>

            <!-- COUNT -->
            <div class="text-end">

                <div class="fw-bold"
                     style="
                        color: white;
                        font-size: 38px;">

                    @Model.Count

                </div>

                <small style="color: #f5ebe0;">

                    Usuarios registrados

                </small>

            </div>

        </div>

        <!-- BODY -->
        <div class="p-4">

            <div class="table-responsive">

                <table class="table align-middle mb-0">

                    <thead>

                        <tr style="border-bottom: 1px solid #f1e3d3;">

                            <th class="border-0 py-4"
                                style="
                                    color: #8b735f;
                                    font-size: 13px;
                                    letter-spacing: 1px;">

                                USUARIO

                            </th>

                            <th class="border-0 py-4"
                                style="
                                    color: #8b735f;
                                    font-size: 13px;
                                    letter-spacing: 1px;">

                                CORREO

                            </th>

                            <th class="border-0 py-4"
                                style="
                                    color: #8b735f;
                                    font-size: 13px;
                                    letter-spacing: 1px;">

                                ROL ACTUAL

                            </th>

                            <th class="border-0 py-4"
                                style="
                                    color: #8b735f;
                                    font-size: 13px;
                                    letter-spacing: 1px;">

                                CAMBIAR ROL

                            </th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var usuario in Model)
                        {
                            <tr style="
                                    border-bottom: 1px solid #f3ebe5;
                                    transition: 0.3s;">

                                <!-- USER -->
                                <td class="py-4">

                                    <div class="d-flex align-items-center">

                                        <!-- AVATAR -->
                                        <div class="rounded-circle d-flex justify-content-center align-items-center me-3 shadow-sm"
                                             style="
                                                width: 52px;
                                                height: 52px;
                                                background: linear-gradient(135deg, #b08968, #7f5539);
                                                color: white;
                                                font-weight: bold;
                                                font-size: 18px;">

                                            @(usuario.NombreCompleto.Substring(0,1).ToUpper())

                                        </div>

                                        <!-- NAME -->
                                        <div>

                                            <div class="fw-bold"
                                                 style="
                                                    color: #4b3a30;
                                                    font-size: 16px;">

                                                @usuario.NombreCompleto

                                            </div>

                                            <small style="color: #8b735f;">

                                                Usuario activo

                                            </small>

                                        </div>

                                    </div>

                                </td>

                                <!-- EMAIL -->
                                <td class="py-4">

                                    <span style="
                                            color: #5c4435;
                                            font-size: 15px;">

                                        <i class="bi bi-envelope-fill me-2"
                                           style="color: #9c6644;"></i>

                                        @usuario.Email

                                    </span>

                                </td>

                                <!-- ROLE -->
                                <td class="py-4">

                                    <span class="px-3 py-2 rounded-pill fw-semibold"
                                          style="
                                            background-color: #ede0d4;
                                            color: #6b4f3f;
                                            font-size: 14px;">

                                        @string.Join(", ", usuario.Roles)

                                    </span>

                                </td>

                                <!-- CHANGE ROLE -->
                                <td class="py-4">

                                    <form asp-action="CambiarRol"
                                          method="post"
                                          class="d-flex gap-2 flex-wrap">

                                        <input type="hidden"
                                               name="usuarioId"
                                               value="@usuario.Id" />

                                        <select name="nuevoRol"
                                                class="form-select border-0 shadow-sm rounded-4"
                                                style="
                                                    background-color: #f8f3ee;
                                                    color: #5c4435;
                                                    min-width: 170px;">

                                            <option value="Admin">Admin</option>
                                            <option value="Editor">Editor</option>
                                            <option value="Viewer">Viewer</option>
                                            <option value="Vendedor">Vendedor</option>

                                        </select>

                                        <button class="btn px-4 rounded-4 fw-semibold shadow-sm border-0"
                                                type="submit"
                                                style="
                                                    background: linear-gradient(135deg, #b08968, #7f5539);
                                                    color: white;">

                                            <i class="bi bi-arrow-repeat me-2"></i>
                                            Cambiar

                                        </button>

                                    </form>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>