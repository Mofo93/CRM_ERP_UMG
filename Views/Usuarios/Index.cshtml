@model List<UsuarioListadoVista>
<div class="d-flex justify-content-between align-items-center mb-3">
<h2>Usuarios y roles</h2>
<a class="btn btn-primary" asp-action="Crear">Crear usuario</a>
</div>
<div class="card shadow-sm">
<div class="card-body table-responsive">
<table class="table table-striped">
<thead class="table-dark">
<tr>
<th>Nombre</th>
<th>Correo</th>
<th>Rol actual</th>
<th>Cambiar rol</th>
</tr>
</thead>
<tbody>
@foreach (var usuario in Model)
{
<tr>
<td>@usuario.NombreCompleto</td>
<td>@usuario.Email</td>
<td>@string.Join(", ", usuario.Roles)</td>
<td>
<form asp-action="CambiarRol" method="post" class="d-flex
gap-2">
<input type="hidden" name="usuarioId" value="@usuario.Id" />
<select name="nuevoRol" class="form-select form-select-sm">
<option value="Admin">Admin</option>
<option value="Editor">Editor</option>
<option value="Viewer">Viewer</option>
<option value="Vendedor">Vendedor</option>
</select>
<button class="btn btn-sm btn-warning"
type="submit">Cambiar</button>
</form>
</td>
</tr>
}
</tbody>
</table>
</div>
</div>