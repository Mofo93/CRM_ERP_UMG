@model CrearUsuarioVista

<div class="container-fluid px-4 py-4">

    <!-- HEADER -->
    <div class="mb-5">

        <h1 class="fw-bold mb-2"
            style="color: #4b3a30;">

            Crear Usuario

        </h1>

        <p style="
                color: #8b735f;
                font-size: 15px;">

            Registra nuevos usuarios y asigna permisos dentro del sistema ERP

        </p>

    </div>

    <div class="row justify-content-center">

        <div class="col-xl-8 col-lg-10">

            <!-- CARD -->
            <div class="card border-0 rounded-5 overflow-hidden shadow-lg"
                 style="
                    background-color: #fffaf5;">

                <!-- TOP -->
                <div class="px-5 py-4"
                     style="
                        background: linear-gradient(135deg, #9c6644, #7f5539);">

                    <div class="d-flex align-items-center">

                        <!-- ICON -->
                        <div class="rounded-4 d-flex justify-content-center align-items-center me-4"
                             style="
                                width: 75px;
                                height: 75px;
                                background: rgba(255,255,255,0.15);">

                            <i class="bi bi-person-fill-add"
                               style="
                                    font-size: 32px;
                                    color: white;"></i>

                        </div>

                        <!-- TEXT -->
                        <div>

                            <h2 class="fw-bold text-white mb-1">

                                Nuevo Usuario

                            </h2>

                            <span style="color: #f5ebe0;">

                                Gestión segura de accesos y permisos

                            </span>

                        </div>

                    </div>

                </div>

                <!-- BODY -->
                <div class="card-body p-5">

                    <form asp-action="Crear" method="post">

                        <!-- VALIDATION -->
                        <div asp-validation-summary="ModelOnly"
                             class="alert border-0 rounded-4 shadow-sm mb-4"
                             style="
                                background-color: #f8ede3;
                                color: #7f5539;">
                        </div>

                        <div class="row g-4">

                            <!-- NOMBRE -->
                            <div class="col-md-6">

                                <label asp-for="NombreCompleto"
                                       class="form-label fw-semibold mb-2"
                                       style="color: #5c4435;">

                                    Nombre completo

                                </label>

                                <div class="input-group shadow-sm rounded-4 overflow-hidden">

                                    <span class="input-group-text border-0 px-4"
                                          style="background-color: #efe3d8;">

                                        <i class="bi bi-person-fill"
                                           style="color: #9c6644;"></i>

                                    </span>

                                    <input asp-for="NombreCompleto"
                                           class="form-control border-0 py-3"
                                           style="
                                                background-color: #fffdfb;
                                                color: #4b3a30;"
                                           placeholder="Nombre del usuario" />

                                </div>

                            </div>

                            <!-- EMAIL -->
                            <div class="col-md-6">

                                <label asp-for="Email"
                                       class="form-label fw-semibold mb-2"
                                       style="color: #5c4435;">

                                    Correo electrónico

                                </label>

                                <div class="input-group shadow-sm rounded-4 overflow-hidden">

                                    <span class="input-group-text border-0 px-4"
                                          style="background-color: #efe3d8;">

                                        <i class="bi bi-envelope-fill"
                                           style="color: #9c6644;"></i>

                                    </span>

                                    <input asp-for="Email"
                                           class="form-control border-0 py-3"
                                           style="
                                                background-color: #fffdfb;
                                                color: #4b3a30;"
                                           placeholder="usuario@empresa.com" />

                                </div>

                            </div>

                            <!-- PASSWORD -->
                            <div class="col-md-6">

                                <label asp-for="Password"
                                       class="form-label fw-semibold mb-2"
                                       style="color: #5c4435;">

                                    Contraseña

                                </label>

                                <div class="input-group shadow-sm rounded-4 overflow-hidden">

                                    <span class="input-group-text border-0 px-4"
                                          style="background-color: #efe3d8;">

                                        <i class="bi bi-lock-fill"
                                           style="color: #9c6644;"></i>

                                    </span>

                                    <input asp-for="Password"
                                           type="password"
                                           class="form-control border-0 py-3"
                                           style="
                                                background-color: #fffdfb;
                                                color: #4b3a30;"
                                           placeholder="••••••••" />

                                </div>

                            </div>

                            <!-- ROL -->
                            <div class="col-md-6">

                                <label asp-for="Rol"
                                       class="form-label fw-semibold mb-2"
                                       style="color: #5c4435;">

                                    Rol del usuario

                                </label>

                                <div class="input-group shadow-sm rounded-4 overflow-hidden">

                                    <span class="input-group-text border-0 px-4"
                                          style="background-color: #efe3d8;">

                                        <i class="bi bi-shield-lock-fill"
                                           style="color: #9c6644;"></i>

                                    </span>

                                    <select asp-for="Rol"
                                            class="form-select border-0 py-3"
                                            style="
                                                background-color: #fffdfb;
                                                color: #4b3a30;">

                                        @foreach (var rol in Model.RolesDisponibles)
                                        {
                                            <option value="@rol">
                                                @rol
                                            </option>
                                        }

                                    </select>

                                </div>

                            </div>

                        </div>

                        <!-- ACTIONS -->
                        <div class="d-flex justify-content-between align-items-center mt-5 flex-wrap gap-3">

                            <a asp-action="Index"
                               class="btn px-4 py-3 rounded-4 fw-semibold shadow-sm border-0"
                               style="
                                    background-color: #ede0d4;
                                    color: #6b4f3f;">

                                <i class="bi bi-arrow-left-circle me-2"></i>
                                Cancelar

                            </a>

                            <button type="submit"
                                    class="btn px-5 py-3 rounded-4 fw-bold shadow-lg border-0"
                                    style="
                                        background: linear-gradient(135deg, #b08968, #7f5539);
                                        color: white;">

                                <i class="bi bi-check-circle-fill me-2"></i>
                                Crear Usuario

                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>