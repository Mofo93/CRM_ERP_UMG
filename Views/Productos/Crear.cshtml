@model Producto

<div class="container-fluid px-4 py-4">

    <!-- HEADER -->
    <div class="mb-5">

        <h1 class="fw-bold mb-2"
            style="
                color: #4b3a30;
                font-size: 38px;">

            Nuevo Producto

        </h1>

        <p style="
                color: #8b735f;
                font-size: 15px;">

            Registra productos dentro del inventario del sistema ERP

        </p>

    </div>

    <div class="row justify-content-center">

        <div class="col-xl-9 col-lg-10">

            <!-- CARD -->
            <div class="card border-0 rounded-5 overflow-hidden shadow-lg"
                 style="background-color: #fffaf5;">

                <!-- TOP -->
                <div class="px-5 py-4"
                     style="
                        background: linear-gradient(135deg, #9c6644, #7f5539);">

                    <div class="d-flex align-items-center">

                        <!-- ICON -->
                        <div class="rounded-4 d-flex justify-content-center align-items-center me-4"
                             style="
                                width: 75px;
                                height: 75px;
                                background: rgba(255,255,255,0.15);">

                            <i class="bi bi-box-seam-fill"
                               style="
                                    font-size: 32px;
                                    color: white;"></i>

                        </div>

                        <!-- TEXT -->
                        <div>

                            <h2 class="fw-bold text-white mb-1">

                                Registro de Producto

                            </h2>

                            <span style="color: #f5ebe0;">

                                Administración moderna de inventario y productos

                            </span>

                        </div>

                    </div>

                </div>

                <!-- BODY -->
                <div class="card-body p-5">

                    <form asp-action="Crear" method="post">

                        <div class="row g-4">

                            <!-- CODIGO -->
                            <div class="col-md-6">

                                <label class="form-label fw-semibold mb-2"
                                       style="color: #5c4435;">

                                    Código

                                </label>

                                <div class="input-group shadow-sm rounded-4 overflow-hidden">

                                    <span class="input-group-text border-0 px-4"
                                          style="background-color: #efe3d8;">

                                        <i class="bi bi-upc-scan"
                                           style="color: #9c6644;"></i>

                                    </span>

                                    <input asp-for="Codigo"
                                           required
                                           class="form-control border-0 py-3"
                                           style="
                                                background-color: #fffdfb;
                                                color: #4b3a30;" />

                                </div>

                            </div>

                            <!-- PRECIO -->
                            <div class="col-md-6">

                                <label class="form-label fw-semibold mb-2"
                                       style="color: #5c4435;">

                                    Precio de venta

                                </label>

                                <div class="input-group shadow-sm rounded-4 overflow-hidden">

                                    <span class="input-group-text border-0 px-4"
                                          style="background-color: #efe3d8;">

                                        <i class="bi bi-cash-stack"
                                           style="color: #9c6644;"></i>

                                    </span>

                                    <input asp-for="PrecioVenta"
                                           type="number"
                                           step="any"
                                           required
                                           class="form-control border-0 py-3"
                                           style="
                                                background-color: #fffdfb;
                                                color: #4b3a30;" />

                                </div>

                            </div>

                            <!-- NOMBRE -->
                            <div class="col-12">

                                <label class="form-label fw-semibold mb-2"
                                       style="color: #5c4435;">

                                    Nombre del producto

                                </label>

                                <div class="input-group shadow-sm rounded-4 overflow-hidden">

                                    <span class="input-group-text border-0 px-4"
                                          style="background-color: #efe3d8;">

                                        <i class="bi bi-tag-fill"
                                           style="color: #9c6644;"></i>

                                    </span>

                                    <input asp-for="Nombre"
                                           required
                                           class="form-control border-0 py-3"
                                           style="
                                                background-color: #fffdfb;
                                                color: #4b3a30;" />

                                </div>

                            </div>

                            <!-- DESCRIPCION -->
                            <div class="col-12">

                                <label class="form-label fw-semibold mb-2"
                                       style="color: #5c4435;">

                                    Descripción

                                </label>

                                <div class="input-group shadow-sm rounded-4 overflow-hidden">

                                    <span class="input-group-text border-0 px-4 align-items-start pt-3"
                                          style="background-color: #efe3d8;">

                                        <i class="bi bi-card-text"
                                           style="color: #9c6644;"></i>

                                    </span>

                                    <textarea asp-for="Descripcion"
                                              rows="4"
                                              class="form-control border-0 py-3"
                                              style="
                                                    background-color: #fffdfb;
                                                    color: #4b3a30;
                                                    resize: none;"></textarea>

                                </div>

                            </div>

                            <!-- EXISTENCIA -->
                            <div class="col-md-6">

                                <label class="form-label fw-semibold mb-2"
                                       style="color: #5c4435;">

                                    Existencia

                                </label>

                                <div class="input-group shadow-sm rounded-4 overflow-hidden">

                                    <span class="input-group-text border-0 px-4"
                                          style="background-color: #efe3d8;">

                                        <i class="bi bi-boxes"
                                           style="color: #9c6644;"></i>

                                    </span>

                                    <input asp-for="Existencia"
                                           type="number"
                                           step="any"
                                           required
                                           class="form-control border-0 py-3"
                                           style="
                                                background-color: #fffdfb;
                                                color: #4b3a30;" />

                                </div>

                            </div>

                        </div>

                        <!-- ACTIONS -->
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mt-5">

                            <a asp-action="Index"
                               class="btn px-4 py-3 rounded-4 fw-semibold shadow-sm border-0"
                               style="
                                    background-color: #ede0d4;
                                    color: #6b4f3f;">

                                <i class="bi bi-arrow-left-circle me-2"></i>
                                Cancelar

                            </a>

                            <button type="submit"
                                    class="btn px-5 py-3 rounded-4 fw-bold shadow-lg border-0"
                                    style="
                                        background: linear-gradient(135deg, #b08968, #7f5539);
                                        color: white;">

                                <i class="bi bi-check-circle-fill me-2"></i>
                                Guardar Producto

                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>