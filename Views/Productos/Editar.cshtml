@model Producto
<h2>Editar producto</h2>
<form asp-action="Editar" method="post" class="card shadow-sm p-4">
<input type="hidden" asp-for="Id" />
<input type="hidden" asp-for="FechaCreacion" />
<div class="mb-3">
<label class="form-label">Código</label>
<input asp-for="Codigo" class="form-control" required />
</div>
<div class="mb-3">
<label class="form-label">Nombre</label>
<input asp-for="Nombre" class="form-control" required />
</div>
<div class="mb-3">
<label class="form-label">Descripción</label>
<textarea asp-for="Descripcion" class="form-control"></textarea>
</div>
<div class="mb-3">
<label class="form-label">Precio de venta</label>
<input asp-for="PrecioVenta" type="number" step="any" class="form-control"
required />
</div>
<div class="mb-3">
<label class="form-label">Existencia</label>
<input asp-for="Existencia" type="number" step="any" class="form-control"
required />
</div>
<div class="form-check mb-3">
<input asp-for="Activo" class="form-check-input" />
<label class="form-check-label">Activo</label>
</div>
<button class="btn btn-primary" type="submit">Guardar cambios</button>
<a class="btn btn-secondary" asp-action="Index">Cancelar</a>
</form>
