@model List<Producto>

<div class="container-fluid px-4 py-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-5">

        <div>

            <h1 class="fw-bold mb-2"
                style="
                    color: #4b3a30;
                    font-size: 38px;">

                Productos

            </h1>

            <p class="mb-0"
               style="
                    color: #8b735f;
                    font-size: 15px;">

                Administración y control general de inventario

            </p>

        </div>

        <!-- BUTTON -->
        <a asp-action="Crear"
           class="btn border-0 px-4 py-3 rounded-4 fw-semibold shadow-lg"
           style="
                background: linear-gradient(135deg, #b08968, #7f5539);
                color: white;
                min-width: 220px;">

            <i class="bi bi-plus-circle-fill me-2"></i>
            Nuevo Producto

        </a>

    </div>

    <!-- MAIN PANEL -->
    <div class="card border-0 rounded-5 overflow-hidden shadow-lg"
         style="
            background-color: #fffaf5;">

        <!-- TOP -->
        <div class="px-5 py-4 d-flex justify-content-between align-items-center flex-wrap gap-3"
             style="
                background: linear-gradient(135deg, #9c6644, #7f5539);">

            <!-- LEFT -->
            <div class="d-flex align-items-center">

                <div class="rounded-4 d-flex justify-content-center align-items-center me-4 shadow"
                     style="
                        width: 70px;
                        height: 70px;
                        background: rgba(255,255,255,0.15);">

                    <i class="bi bi-box-seam-fill"
                       style="
                            font-size: 30px;
                            color: white;"></i>

                </div>

                <div>

                    <h3 class="fw-bold text-white mb-1">
                        Gestión de Productos
                    </h3>

                    <span style="color: #f5ebe0;">

                        Visualización y control del inventario

                    </span>

                </div>

            </div>

            <!-- RIGHT -->
            <div class="text-end">

                <div class="fw-bold"
                     style="
                        color: white;
                        font-size: 38px;">

                    @Model.Count

                </div>

                <small style="color: #f5ebe0;">

                    Productos registrados

                </small>

            </div>

        </div>

        <!-- TABLE -->
        <div class="p-4">

            <div class="table-responsive">

                @if (!Model.Any())
                {
                    <div class="rounded-4 p-5 text-center"
                         style="
                            background-color: #f5ebe0;">

                        <i class="bi bi-box"
                           style="
                                font-size: 55px;
                                color: #9c6644;"></i>

                        <h4 class="fw-bold mt-4"
                            style="color: #6b4f3f;">

                            No hay productos registrados

                        </h4>

                        <p style="color: #8b735f;">

                            Comienza agregando un nuevo producto al inventario

                        </p>

                    </div>
                }
                else
                {
                    <table class="table align-middle mb-0">

                        <thead>

                            <tr style="border-bottom: 1px solid #e8d8cb;">

                                <th class="border-0 py-4"
                                    style="
                                        color: #8b735f;
                                        font-size: 13px;
                                        letter-spacing: 1px;">

                                    CÓDIGO

                                </th>

                                <th class="border-0 py-4"
                                    style="
                                        color: #8b735f;
                                        font-size: 13px;
                                        letter-spacing: 1px;">

                                    PRODUCTO

                                </th>

                                <th class="border-0 py-4"
                                    style="
                                        color: #8b735f;
                                        font-size: 13px;
                                        letter-spacing: 1px;">

                                    PRECIO

                                </th>

                                <th class="border-0 py-4"
                                    style="
                                        color: #8b735f;
                                        font-size: 13px;
                                        letter-spacing: 1px;">

                                    EXISTENCIA

                                </th>

                                <th class="border-0 py-4"
                                    style="
                                        color: #8b735f;
                                        font-size: 13px;
                                        letter-spacing: 1px;">

                                    ESTADO

                                </th>

                                <th class="border-0 py-4 text-end"
                                    style="
                                        color: #8b735f;
                                        font-size: 13px;
                                        letter-spacing: 1px;">

                                    ACCIONES

                                </th>

                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var producto in Model)
                            {
                                <tr style="
                                        border-bottom: 1px solid #f1e4d8;
                                        transition: 0.3s;">

                                    <!-- CODIGO -->
                                    <td class="py-4">

                                        <span class="px-3 py-2 rounded-pill fw-semibold"
                                              style="
                                                background-color: #ede0d4;
                                                color: #6b4f3f;
                                                font-size: 14px;">

                                            @producto.Codigo

                                        </span>

                                    </td>

                                    <!-- PRODUCTO -->
                                    <td class="py-4">

                                        <div class="d-flex align-items-center">

                                            <!-- ICON -->
                                            <div class="rounded-circle d-flex justify-content-center align-items-center me-3 shadow-sm"
                                                 style="
                                                    width: 50px;
                                                    height: 50px;
                                                    background: linear-gradient(135deg, #b08968, #7f5539);
                                                    color: white;
                                                    font-weight: bold;
                                                    font-size: 18px;">

                                                @(producto.Nombre.Substring(0,1).ToUpper())

                                            </div>

                                            <!-- TEXT -->
                                            <div>

                                                <div class="fw-bold"
                                                     style="
                                                        color: #4b3a30;
                                                        font-size: 16px;">

                                                    @producto.Nombre

                                                </div>

                                                <small style="color: #8b735f;">

                                                    Producto en inventario

                                                </small>

                                            </div>

                                        </div>

                                    </td>

                                    <!-- PRECIO -->
                                    <td class="py-4">

                                        <span class="fw-bold"
                                              style="
                                                    color: #7f5539;
                                                    font-size: 16px;">

                                            Q @producto.PrecioVenta

                                        </span>

                                    </td>

                                    <!-- EXISTENCIA -->
                                    <td class="py-4">

                                        <span class="px-3 py-2 rounded-pill fw-semibold"
                                              style="
                                                    background-color: #f5ebe0;
                                                    color: #7f5539;">

                                            @producto.Existencia unidades

                                        </span>

                                    </td>

                                    <!-- ESTADO -->
                                    <td class="py-4">

                                        @if (producto.Activo)
                                        {
                                            <span class="px-3 py-2 rounded-pill fw-semibold"
                                                  style="
                                                        background-color: #d8f3dc;
                                                        color: #2d6a4f;">

                                                <i class="bi bi-check-circle-fill me-1"></i>
                                                Activo

                                            </span>
                                        }
                                        else
                                        {
                                            <span class="px-3 py-2 rounded-pill fw-semibold"
                                                  style="
                                                        background-color: #ffe5e5;
                                                        color: #b02a37;">

                                                <i class="bi bi-x-circle-fill me-1"></i>
                                                Inactivo

                                            </span>
                                        }

                                    </td>

                                    <!-- ACTIONS -->
                                    <td class="py-4 text-end">

                                        <a asp-action="Editar"
                                           asp-route-id="@producto.Id"
                                           class="btn px-4 py-2 rounded-4 fw-semibold border-0 shadow-sm"
                                           style="
                                                background: linear-gradient(135deg, #b08968, #7f5539);
                                                color: white;">

                                            <i class="bi bi-pencil-square me-2"></i>
                                            Editar

                                        </a>

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>
                }

            </div>

        </div>

    </div>

</div>