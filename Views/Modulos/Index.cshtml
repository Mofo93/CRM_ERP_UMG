@model List<ModuloDinamico>
<div class="d-flex justify-content-between align-items-center mb-3">
<h2>Módulos dinámicos</h2>
@if (User.IsInRole("Admin") || User.IsInRole("Editor"))
{
<a class="btn btn-primary" asp-action="Crear">Crear módulo</a>
}
</div>
@if (TempData["Ok"] != null)
{
<div class="alert alert-success">@TempData["Ok"]</div>
}
@if (TempData["Error"] != null)
{
<div class="alert alert-danger">@TempData["Error"]</div>
}
<div class="row">
@foreach (var modulo in Model)
{
<div class="col-md-4 mb-3">
<div class="card shadow-sm h-100">
<div class="card-body">
<h5>@modulo.NombreModulo</h5>
<p class="text-muted">@modulo.Descripcion</p>
<p>
<span class="badge
bg-secondary">@modulo.EsquemaCampos.Count campos</span>
</p>
<a class="btn btn-sm btn-outline-primary" asp-action="Detalle"
asp-route-id="@modulo.Id">Configurar</a>
<a class="btn btn-sm btn-outline-success" asp-controller="Registros"
asp-action="Index" asp-route-moduloId="@modulo.Id">Registros</a>
<a class="btn btn-sm btn-outline-dark" asp-controller="Operaciones"
asp-action="Index" asp-route-moduloId="@modulo.Id">Operaciones</a>
</div>
</div>
</div>
}
</div>